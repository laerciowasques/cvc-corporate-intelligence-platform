{
  "version": 2,
  "name": "cvc-corporate-intelligence",
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/CVC_Corporate_Intelligence_Platform.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
